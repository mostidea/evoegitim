function turkcetarih($f, $zt = 'now')
{
    if($zt==""){ return ""; exit(); }
    $z = date("$f", strtotime($zt));
    $donustur = array(
        'Monday'    => 'Pazartesi', 'Tuesday'   => 'Salı', 'Wednesday' => 'Çarşamba', 'Thursday'  => 'Perşembe',
        'Friday'    => 'Cuma', 'Saturday'  => 'Cumartesi', 'Sunday'    => 'Pazar', 'January'   => 'Ocak',
        'February'  => 'Şubat', 'March'     => 'Mart', 'April'     => 'Nisan', 'May'       => 'Mayıs',
        'June'      => 'Haziran', 'July'      => 'Temmuz', 'August'    => 'Ağustos', 'September' => 'Eylül',
        'October'   => 'Ekim', 'November'  => 'Kasım', 'December'  => 'Aralık', 'Mon'       => 'Pts',
        'Tue'       => 'Sal', 'Wed'       => 'Çar', 'Thu'       => 'Per', 'Fri'       => 'Cum',
        'Sat'       => 'Cts', 'Sun'       => 'Paz', 'Jan'       => 'Oca', 'Feb'       => 'Şub',
        'Mar'       => 'Mar', 'Apr'       => 'Nis', 'Jun'       => 'Haz', 'Jul'       => 'Tem',
        'Aug'       => 'Ağu', 'Sep'       => 'Eyl', 'Oct'       => 'Eki', 'Nov'       => 'Kas', 'Dec'       => 'Ara',
    );
    foreach ($donustur as $en => $tr) {
        $z = str_replace($en, $tr, $z);
    }
    if (strpos($z, 'Mayıs') !== false && strpos($f, 'F') === false) $z = str_replace('Mayıs', 'May', $z);
    return $z;
}

function sendSms($message,$receiver){
    $receiver = array_unique($receiver);
    $params = [
        'api_id' => SMS_API_ID,
        'api_key' => SMS_API_KEY,
        'sender' => 'EVOEGITIM',
        'message_type' => 'normal',
        'message' => $message,
        'message_content_type' => 'bilgi',
        'phones' => $receiver
    ];
    $curl = curl_init();
    $curl_options = [
        CURLOPT_URL => 'https://api.vatansms.net/api/v1/1toN',
        CURLOPT_RETURNTRANSFER => true,
        CURLOPT_TIMEOUT => 0,
        CURLOPT_FOLLOWLOCATION => true,
        CURLOPT_CUSTOMREQUEST => 'POST',
        CURLOPT_SSL_VERIFYPEER => 0,
        CURLOPT_POSTFIELDS => json_encode($params),
        CURLOPT_HTTPHEADER => ['Content-Type: application/json']
    ];
    curl_setopt_array($curl, $curl_options);
    $response = curl_exec($curl);
    curl_close($curl);
   
}

function checkSession(){
    if (isset($_SESSION["user_id"])) { header("location: dashboard.php"); }
}

function checkUnSession() {
    if (!isset($_SESSION["user_id"])) {
        header("location: index.php");
        exit();
    }

    if (empty($_SESSION['csrf_token'])) {
        $_SESSION['csrf_token'] = bin2hex(random_bytes(32));
    }

    // Panel uyuşmazlığı: hangi panele login olunduğunu URL ile karşılaştır
    $uri   = $_SERVER['REQUEST_URI'] ?? '';
    $panel = $_SESSION['panel'] ?? '';

    $rules = [
        '/teacher/'    => 'teacher',
        '/student/'    => 'student',
        '/vbs/'        => 'vbs',
        '/management/' => 'management',
    ];

    foreach ($rules as $path => $expected) {
        if (strpos($uri, $path) !== false) {
            if (!empty($panel) && $panel !== $expected) {
                session_destroy();
                header("location: " . $path . "index.php?error=access");
                exit();
            }
            if (empty($panel)) {
                $_SESSION['panel'] = $expected;
            }
            break;
        }
    }
}

function parentInviteEmailExists(PDO $db, string $parentEmail, string $currentStudentEmail = ''): bool {
    $parentEmail = trim(strtolower($parentEmail));

    if ($parentEmail === '') {
        return false;
    }

    $parentCheck = $db->prepare("SELECT id FROM parent WHERE LOWER(email) = :email LIMIT 1");
    $parentCheck->execute([':email' => $parentEmail]);
    if ($parentCheck->fetch(PDO::FETCH_ASSOC)) {
        return true;
    }

    $inviteCheck = $db->prepare("SELECT id FROM invite_parent WHERE LOWER(email) = :email LIMIT 1");
    $inviteCheck->execute([':email' => $parentEmail]);

    return (bool) $inviteCheck->fetch(PDO::FETCH_ASSOC);
}

function getRateClass($rate) {
    switch ($rate) {
        case "Çok Kötü": return "text-danger bg-danger-100";
        case "Kötü": return "text-warning bg-warning-100";
        case "İyi":
        case "Çok İyi": return "text-success bg-success-100";
        case "Evet": return "text-success bg-success-100";
        case "Hayır": return "text-danger bg-danger-100";
        default: return "text-primary-600 bg-primary-100";
    }
}

function getStudentInfo($db, $email) {
    $getMyStudent = $db->prepare("SELECT * FROM invite_parent WHERE email = :email ORDER BY id DESC");
    $getMyStudent->bindParam(":email", $email);
    $getMyStudent->execute();
    $student = $getMyStudent->fetch(PDO::FETCH_ASSOC);

    if ($student) {
        $studentId = $db->prepare("SELECT * FROM users WHERE email = :user_email");
        $studentId->bindParam(":user_email", $student["user_email"]);
        $studentId->execute();
        $studentInfo = $studentId->fetch(PDO::FETCH_ASSOC);
        return ['invite_parent_info' => $student, 'user_info' => $studentInfo];
    }
    return false;
}

function getStudentInfoMultiple($db, $email) {
    $getMyStudents = $db->prepare("SELECT * FROM invite_parent WHERE email = :email");
    $getMyStudents->bindParam(":email", $email);
    $getMyStudents->execute();
    $students = $getMyStudents->fetchAll(PDO::FETCH_ASSOC);
    $results = [];
    foreach ($students as $student) {
        $studentId = $db->prepare("SELECT id, fullname FROM users WHERE email = :user_email");
        $studentId->bindParam(":user_email", $student["user_email"]);
        $studentId->execute();
        $studentInfo = $studentId->fetch(PDO::FETCH_ASSOC);
        if ($studentInfo) {
            $results[] = ['invite_parent_info' => $student, 'user_info' => $studentInfo];
        }
    }
    return $results;
}

function getUserPhone($db,$uid){
    $data = $db->prepare("SELECT phone FROM users WHERE id = :uid");
    $data->bindValue(':uid', $uid);
    $data->execute();
    $row = $data->fetch(PDO::FETCH_ASSOC);
    return $row ? $row['phone'] : "";
}

function getParentPhone($db,$uid){
    $data = $db->prepare("SELECT phone FROM parent WHERE id = :uid");
    $data->bindValue(':uid', $uid);
    $data->execute();
    $row = $data->fetch(PDO::FETCH_ASSOC);
    return $row ? $row['phone'] : "";
}

function getParentInfo($db, $email) {
    $studentId = $db->prepare("SELECT * FROM invite_parent WHERE user_email = :user_email");
    $studentId->bindParam(":user_email", $email);
    $studentId->execute();
    $veliInfo = $studentId->fetch(PDO::FETCH_ASSOC);
    $veliId = $db->prepare("SELECT * FROM parent WHERE email = :user_email");
    $veliId->bindParam(":user_email", $veliInfo["email"]);
    $veliId->execute();
    $veliid = $veliId->fetch(PDO::FETCH_ASSOC);
    return @$veliid["id"];
}

