}

function getStudentEmail($db, $email) {
    $studentId = $db->prepare("SELECT * FROM invite_parent WHERE email = :user_email");
    $studentId->bindParam(":user_email", $email);
    $studentId->execute();
    $veliInfo = $studentId->fetch(PDO::FETCH_ASSOC);
